    },

    "Approval": {
      "@id": "coupa:Approval",
      "@context": {
        "id": {
          "@id": "coupa:identifier",
          "@type": "xsd:integer"
        },
        "status": {
          "@id": "coupa:status",
          "@type": "xsd:string"
        }
      }
    }
  }
}
